{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Splendor",
  "colors": {
    "primary": "#00803d",
    "light": "#00b356",
    "dark": "#1aff88"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }
  },
  "styling": {
    "eyebrows": "section"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "concepts/overview"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/tenancy",
              "concepts/datasets",
              "concepts/search-model",
              "concepts/handles-and-cursors",
              "concepts/views",
              "concepts/provenance"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "/api-reference/openapi.json"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Console",
        "href": "https://app.splendor.io"
      }
    ],
    "primary": {
      "type": "button",
